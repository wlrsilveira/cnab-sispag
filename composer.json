{
    "name": "wlrsilveira/cnab-sispag",
    "description": "PHP library for Itaú SISPAG CNAB 240 remittance and return files",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/wlrsilveira/cnab-sispag",
    "support": {
        "issues": "https://github.com/wlrsilveira/cnab-sispag/issues",
        "source": "https://github.com/wlrsilveira/cnab-sispag"
    },
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CnabSispag\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CnabSispag\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
